PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Controla o backend de persistencia do Core SaaS.
# memory: padrao atual. Usa store em memoria. Nao exige DATABASE_URL.
# prisma: usa PostgreSQL via Prisma. Exige DATABASE_URL valido e migrations aplicadas.
#         Ainda e modo controlado/experimental ate a migracao completa das rotas.
CORE_SAAS_PERSISTENCE="memory"

# Exemplo local de desenvolvimento. Nao use esta DATABASE_URL como segredo de producao.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/erp_techsolutions?schema=public"
REDIS_URL="redis://localhost:6379"

# Senha local de desenvolvimento para o admin demo criado pelo seed.
# Nunca use este valor em producao; defina um segredo proprio fora do repositorio.
DEMO_ADMIN_PASSWORD="ChangeMe123!"

# JWT local/dev. Troque em qualquer ambiente compartilhado/producao.
# Nao use um JWT_SECRET real em arquivos versionados.
JWT_SECRET="dev-only-change-me"
JWT_EXPIRES_IN="15m"

CORS_ORIGIN="http://localhost:5173"

# Nunca versione o arquivo .env real.

