PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Controla o backend de persistencia do Core SaaS.
# memory: padrao atual. Usa store em memoria. Nao exige DATABASE_URL.
# prisma: usa PostgreSQL via Prisma. Exige DATABASE_URL valido e migrations aplicadas.
#         Ainda e modo controlado/experimental ate a migracao completa das rotas.
CORE_SAAS_PERSISTENCE="memory"

# Exemplo local de desenvolvimento. Nao use esta DATABASE_URL como segredo de producao.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/erp_techsolutions?schema=public"
REDIS_URL="redis://localhost:6379"

# Senha local de desenvolvimento para o admin demo criado pelo seed.
# Nunca use este valor em producao; defina um segredo proprio fora do repositorio.
DEMO_ADMIN_PASSWORD="ChangeMe123!"

# JWT local/dev. Troque em qualquer ambiente compartilhado/producao.
# Nao use um JWT_SECRET real em arquivos versionados.
JWT_SECRET="change-me-in-local-development"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="change-me-refresh-in-local-development"
JWT_REFRESH_EXPIRES_IN="7d"

CHECKLIST_ATTACHMENT_STORAGE_DRIVER="local"
CHECKLIST_ATTACHMENT_STORAGE_PATH="storage/checklist-attachments"
CHECKLIST_ATTACHMENT_MAX_SIZE_MB=10
CHECKLIST_ATTACHMENT_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,application/pdf"

CORS_ORIGIN="http://localhost:5173"

# Frontend local. true usa mocks da Console da Plataforma; false usa a API real.
VITE_USE_MOCKS="true"
VITE_DEFAULT_TENANT_ID=""

# E2E local com Playwright. Overrides opcionais; os defaults ficam na config.
E2E_API_PORT=3200
E2E_FRONTEND_PORT=5173
E2E_DEMO_ADMIN_EMAIL="admin.demo@example.com"
E2E_PLATFORM_EMAIL="platform.admin@erp.local"
E2E_PLATFORM_PASSWORD="platform-admin-dev-password"

# Nunca versione o arquivo .env real.

