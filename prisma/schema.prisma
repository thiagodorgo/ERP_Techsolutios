  metadata         Json
  uploaded_by      String?   @db.Uuid
  created_by       String?   @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at       DateTime? @db.Timestamptz(6)
  work_order       WorkOrder @relation(fields: [tenant_id, work_order_id], references: [tenant_id, id], onDelete: Cascade)
  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@index([tenant_id, work_order_id])
  @@index([tenant_id, status])
  @@map("work_order_attachments")
}

