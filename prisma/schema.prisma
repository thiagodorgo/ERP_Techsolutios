// Ω3-d — Anexo de OS (evidência/documento). Espelha DamageAttachment (storage/DTO), REUSA o
// checklist storage provider (D-014). Net-new: `status` (reserva AV-assíncrono/B-108; default 'stored'),
// `client_action_id` (idempotência tenant-scoped — §6) e `deleted_at` (delete LÓGICO). storage_key/
// provider/checksum são INTERNOS (nunca no DTO — §2.8).
model WorkOrderAttachment {
