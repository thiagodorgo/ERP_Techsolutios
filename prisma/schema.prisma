generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                            String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                          String
  slug                          String                       @unique
  status                        String                       @default("active")
  // Ω-ACESSO — módulos provisionados ao tenant (dinâmico). Governa a visibilidade dos itens de menu
  // com requiredModules (ex.: field_operations habilita o Mapa Operacional). Vazio = nenhum módulo.
  modules                       String[]                     @default([])
  created_at                    DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime                     @default(now()) @updatedAt @db.Timestamptz(6)
  audit_logs                    AuditLog[]
  branches                      Branch[]
  checklist_acknowledgements    ChecklistAcknowledgement[]
  checklist_attachments         ChecklistAttachment[]
  checklist_markers             ChecklistMarker[]
  checklist_run_answers         ChecklistRunAnswer[]
  checklist_runs                ChecklistRun[]
  checklist_template_components ChecklistTemplateComponent[]
  checklist_templates           ChecklistTemplate[]
  customers                     Customer[]
  vehicles                      Vehicle[]
  fuel_logs                     FuelLog[]
  maintenance_orders            MaintenanceOrder[]
  fines                         Fine[]
  insurance_policies            InsurancePolicy[]
  damages                       Damage[]
  damage_attachments            DamageAttachment[]
  work_order_attachments        WorkOrderAttachment[]
  inventory_items               InventoryItem[]
  stock_movements               StockMovement[]
  cycle_counts                  CycleCount[]
  cycle_count_entries           CycleCountEntry[]
  service_catalog_items         ServiceCatalog[]
  price_tables                  PriceTable[]
  tariffs                       Tariff[]
  suppliers                     Supplier[]
  financial_accounts            FinancialAccount[]
  financial_titles              FinancialTitle[]
  financial_period_closes       FinancialPeriodClose[]
  tags                          Tag[]
  pois                          Poi[]
  operator_profiles             OperatorProfile[]
  tenant_settings               TenantSetting[]
  teams                         Team[]
  team_members                  TeamMember[]
  field_operator_locations      FieldOperatorLocation[]
  field_dispatch_events         FieldDispatchEvent[]
  field_dispatches              FieldDispatch[]
  work_order_assignments        WorkOrderAssignment[]
  work_order_events             WorkOrderEvent[]
  work_orders                   WorkOrder[]
  auth_sessions                 AuthSession[]
  cloud_usage_daily_aggregates  CloudUsageDailyAggregate[]
  cloud_usage_events            CloudUsageEvent[]
  cloud_charge_rules            CloudChargeRule[]
  commission_basis_events       CommissionBasisEvent[]
  commission_calculations       CommissionCalculation[]
  commission_policies           CommissionPolicy[]
  commission_policy_rules       CommissionPolicyRule[]
  commission_statements         CommissionStatement[]
  expense_approval_steps        ExpenseApprovalStep[]
  expense_events                ExpenseEvent[]
  expense_items                 ExpenseItem[]
  expense_policies              ExpensePolicy[]
  expense_receipts              ExpenseReceipt[]
  expense_reports               ExpenseReport[]
  expense_advances              ExpenseAdvance[]
  mobile_action_receipts        MobileActionReceipt[]
  tenant_cloud_charges          TenantCloudCharge[]
  tenant_cloud_cost_allocations TenantCloudCostAllocation[]
  local_auth_credentials        LocalAuthCredential[]
  notifications                 Notification[]
  roles                         Role[]
  user_role_assignments         UserRoleAssignment[]
  users                         User[]

  @@map("tenants")
}

model Branch {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String               @db.Uuid
  name                  String
  code                  String
  status                String               @default("active")
  created_at            DateTime             @default(now()) @db.Timestamptz(6)
  updated_at            DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  tenant                Tenant               @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  user_role_assignments UserRoleAssignment[]
  users                 User[]

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@map("branches")
}

model User {
  id                               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                        String                  @db.Uuid
  branch_id                        String?                 @db.Uuid
  name                             String
  email                            String
  status                           String                  @default("active")
  created_at                       DateTime                @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime                @default(now()) @updatedAt @db.Timestamptz(6)
  audit_logs                       AuditLog[]
  auth_sessions                    AuthSession[]
  branch                           Branch?                 @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  local_auth_credentials           LocalAuthCredential[]
  notifications                    Notification[]
  field_operator_locations         FieldOperatorLocation[]
  field_dispatch_events            FieldDispatchEvent[]    @relation("FieldDispatchEventActor")
  field_dispatches_created         FieldDispatch[]         @relation("FieldDispatchCreatedBy")
  field_dispatches_operator        FieldDispatch[]         @relation("FieldDispatchOperator")
  field_dispatches_updated         FieldDispatch[]         @relation("FieldDispatchUpdatedBy")
  commission_calculations_eligible CommissionCalculation[] @relation("CommissionCalculationEligibleUser")
  commission_calculations_payee    CommissionCalculation[] @relation("CommissionCalculationPayee")
  commission_policies_created      CommissionPolicy[]      @relation("CommissionPolicyCreatedBy")
  commission_statements_payee      CommissionStatement[]   @relation("CommissionStatementPayee")
  expense_approval_steps_actor     ExpenseApprovalStep[]   @relation("ExpenseApprovalStepActor")
  expense_events_actor             ExpenseEvent[]          @relation("ExpenseEventActor")
  expense_reports_created          ExpenseReport[]         @relation("ExpenseReportCreatedBy")
  expense_reports_employee         ExpenseReport[]         @relation("ExpenseReportEmployee")
  expense_advances_employee        ExpenseAdvance[]        @relation("ExpenseAdvanceEmployee")
  mobile_action_receipts_actor     MobileActionReceipt[]   @relation("MobileActionReceiptActor")
  assigned_work_orders             WorkOrder[]             @relation("WorkOrderAssignedUser")
  created_work_orders              WorkOrder[]             @relation("WorkOrderCreatedBy")
  updated_work_orders              WorkOrder[]             @relation("WorkOrderUpdatedBy")
  work_order_assignments           WorkOrderAssignment[]   @relation("WorkOrderAssignmentUser")
  work_order_events                WorkOrderEvent[]        @relation("WorkOrderEventActor")
  role_assignments                 UserRoleAssignment[]
  led_teams                        Team[]                  @relation("TeamLeader")
  team_memberships                 TeamMember[]            @relation("TeamMemberUser")
  operator_profile                 OperatorProfile?
  tenant                           Tenant                  @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@map("users")
}

model LocalAuthCredential {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String    @db.Uuid
  user_id             String    @db.Uuid
  email               String
  password_hash       String
  password_algorithm  String
  password_updated_at DateTime  @default(now()) @db.Timestamptz(6)
  failed_attempts     Int       @default(0)
  locked_until        DateTime? @db.Timestamptz(6)
  last_login_at       DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  tenant              Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  user                User      @relation(fields: [tenant_id, user_id], references: [tenant_id, id], onDelete: Cascade)

  @@unique([tenant_id, user_id])
  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, email])
  @@map("local_auth_credentials")
}

model AuthSession {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String    @db.Uuid
  user_id            String    @db.Uuid
  refresh_token_hash String    @unique
  user_agent         String?
  ip_address         String?
  expires_at         DateTime  @db.Timestamptz(6)
  revoked_at         DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  tenant             Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  user               User      @relation(fields: [tenant_id, user_id], references: [tenant_id, id], onDelete: Cascade)

  @@unique([tenant_id, id])
  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, revoked_at])
  @@index([expires_at])
  @@map("auth_sessions")
}

model Role {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String?              @db.Uuid
  key              String
  name             String
  scope            String
  created_at       DateTime             @default(now()) @db.Timestamptz(6)
  updated_at       DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  tenant           Tenant?              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  role_permissions RolePermission[]
  user_assignments UserRoleAssignment[]

  @@unique([key, tenant_id])
  @@index([tenant_id])
  @@map("roles")
}

model Permission {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key              String           @unique
  description      String
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  role_permissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id       String     @db.Uuid
  permission_id String     @db.Uuid
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
  @@index([permission_id])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  user_id    String   @db.Uuid
  role_id    String   @db.Uuid
  branch_id  String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  branch     Branch?  @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  role       Role     @relation(fields: [role_id], references: [id], onDelete: Restrict)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, user_id, role_id, branch_id])
  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, role_id])
  @@index([branch_id])
  @@map("user_role_assignments")
}

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String   @db.Uuid
  actor_user_id String?  @db.Uuid
  action        String
  entity        String
  entity_id     String?
  metadata      Json?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  actor_user    User?    @relation(fields: [actor_user_id], references: [id], onDelete: SetNull)
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@index([tenant_id])
  @@index([created_at])
  // Ω3F-8a — leitura da auditoria por entidade (aba "Logs da OS"): filtro
  // (tenant_id, entity, entity_id) + ordenação created_at DESC sem varrer o tenant.
  @@index([tenant_id, entity, entity_id, created_at])
  @@map("audit_logs")
}

model Notification {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String    @db.Uuid
  recipient_user_id String    @db.Uuid
  type              String
  title             String
  message           String
  severity          String    @default("info")
  status            String    @default("unread")
  source_type       String?
  source_id         String?
  action_url        String?
  metadata          Json
  idempotency_key   String?
  read_at           DateTime? @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  recipient_user    User      @relation(fields: [tenant_id, recipient_user_id], references: [tenant_id, id], onDelete: Cascade)
  tenant            Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@unique([tenant_id, recipient_user_id, idempotency_key])
  @@index([tenant_id])
  @@index([tenant_id, recipient_user_id])
  @@index([tenant_id, recipient_user_id, status])
  @@index([tenant_id, recipient_user_id, created_at])
  @@index([tenant_id, status, created_at])
  @@map("notifications")
}

model CloudUsageEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  source_type     String
  source_id       String?
  metric_key      String
  quantity        Decimal  @db.Decimal(20, 6)
  unit            String
  occurred_at     DateTime @default(now()) @db.Timestamptz(6)
  idempotency_key String?
  metadata        Json
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  tenant          Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@unique([tenant_id, idempotency_key])
  @@index([tenant_id])
  @@index([tenant_id, metric_key])
  @@index([tenant_id, occurred_at])
  @@index([tenant_id, metric_key, occurred_at])
  @@map("cloud_usage_events")
}

model CloudUsageDailyAggregate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  date        DateTime @db.Date
  metric_key  String
  quantity    Decimal  @db.Decimal(20, 6)
  unit        String
  source_type String
  metadata    Json
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, date, metric_key, unit, source_type])
  @@index([tenant_id])
  @@index([tenant_id, metric_key])
  @@index([tenant_id, date])
  @@map("cloud_usage_daily_aggregates")
}

model CloudCostImport {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider             String
  source_type          String
  source_uri           String?
  status               String              @default("pending")
  period_start         DateTime?           @db.Timestamptz(6)
  period_end           DateTime?           @db.Timestamptz(6)
  imported_at          DateTime?           @db.Timestamptz(6)
  imported_by          String?
  row_count            Int                 @default(0)
  total_unblended_cost Decimal             @default(0) @db.Decimal(20, 6)
  currency             String?
  metadata             Json
  error_message        String?
  created_at           DateTime            @default(now()) @db.Timestamptz(6)
  updated_at           DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  line_items           CloudCostLineItem[]

  @@index([provider])
  @@index([source_type])
  @@index([status])
  @@index([period_start, period_end])
  @@map("cloud_cost_imports")
}

model CloudCostLineItem {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  import_id            String          @db.Uuid
  provider             String
  billing_period_start DateTime        @db.Timestamptz(6)
  billing_period_end   DateTime        @db.Timestamptz(6)
  usage_start          DateTime?       @db.Timestamptz(6)
  usage_end            DateTime?       @db.Timestamptz(6)
  service_code         String
  usage_type           String?
  operation            String?
  region               String?
  resource_id          String?
  cost_category        String?
  environment          String?
  project              String?
  tenant_tag           String?
  module_tag           String?
  usage_amount         Decimal?        @db.Decimal(20, 6)
  usage_unit           String?
  unblended_cost       Decimal         @db.Decimal(20, 6)
  amortized_cost       Decimal?        @db.Decimal(20, 6)
  currency             String
  raw_line_hash        String
  metadata             Json
  created_at           DateTime        @default(now()) @db.Timestamptz(6)
  cost_import          CloudCostImport @relation(fields: [import_id], references: [id], onDelete: Cascade)

  @@unique([import_id, raw_line_hash])
  @@index([import_id])
  @@index([billing_period_start, billing_period_end])
  @@index([service_code])
  @@index([usage_type])
  @@index([region])
  @@index([tenant_tag])
  @@map("cloud_cost_line_items")
}

model CloudCostAllocationRun {
  id                      String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider                String
  status                  String                      @default("pending")
  period_start            DateTime                    @db.Timestamptz(6)
  period_end              DateTime                    @db.Timestamptz(6)
  strategy                String
  total_imported_cost     Decimal                     @default(0) @db.Decimal(20, 6)
  total_allocated_cost    Decimal                     @default(0) @db.Decimal(20, 6)
  total_unallocated_cost  Decimal                     @default(0) @db.Decimal(20, 6)
  currency                String?
  started_at              DateTime?                   @db.Timestamptz(6)
  completed_at            DateTime?                   @db.Timestamptz(6)
  created_by              String?
  error_message           String?
  metadata                Json
  created_at              DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                    @default(now()) @updatedAt @db.Timestamptz(6)
  tenant_allocations      TenantCloudCostAllocation[]
  charge_calculation_runs CloudChargeCalculationRun[]
  tenant_cloud_charges    TenantCloudCharge[]

  @@index([provider])
  @@index([status])
  @@index([period_start, period_end])
  @@map("cloud_cost_allocation_runs")
}

model CloudChargeRule {
  id                        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                 String?             @db.Uuid
  plan_code                 String?
  name                      String
  description               String?
  is_active                 Boolean             @default(true)
  priority                  Int                 @default(100)
  effective_from            DateTime            @db.Timestamptz(6)
  effective_until           DateTime?           @db.Timestamptz(6)
  currency                  String
  markup_type               String
  markup_value              Decimal             @db.Decimal(20, 6)
  minimum_monthly_charge    Decimal             @default(0) @db.Decimal(20, 6)
  included_cloud_cost       Decimal             @default(0) @db.Decimal(20, 6)
  included_usage_amount     Decimal?            @db.Decimal(20, 6)
  included_usage_metric_key String?
  overage_markup_type       String?
  overage_markup_value      Decimal?            @db.Decimal(20, 6)
  rounding_mode             String              @default("nearest_cent")
  metadata                  Json
  created_at                DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  tenant                    Tenant?             @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  tenant_cloud_charges      TenantCloudCharge[]

  @@index([tenant_id])
  @@index([plan_code])
  @@index([is_active])
  @@index([effective_from, effective_until])
  @@map("cloud_charge_rules")
}

model CloudChargeCalculationRun {
  id                       String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status                   String                 @default("pending")
  period_start             DateTime               @db.Timestamptz(6)
  period_end               DateTime               @db.Timestamptz(6)
  source_allocation_run_id String                 @db.Uuid
  strategy                 String
  total_allocated_cost     Decimal                @default(0) @db.Decimal(20, 6)
  total_charge_amount      Decimal                @default(0) @db.Decimal(20, 6)
  total_margin_amount      Decimal                @default(0) @db.Decimal(20, 6)
  total_discount_amount    Decimal                @default(0) @db.Decimal(20, 6)
  currency                 String?
  started_at               DateTime?              @db.Timestamptz(6)
  completed_at             DateTime?              @db.Timestamptz(6)
  created_by               String?
  error_message            String?
  metadata                 Json
  created_at               DateTime               @default(now()) @db.Timestamptz(6)
  updated_at               DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  source_allocation_run    CloudCostAllocationRun @relation(fields: [source_allocation_run_id], references: [id], onDelete: Restrict)
  tenant_cloud_charges     TenantCloudCharge[]

  @@index([status])
  @@index([period_start, period_end])
  @@index([source_allocation_run_id])
  @@map("cloud_charge_calculation_runs")
}

model TenantCloudCharge {
  id                       String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  calculation_run_id       String                    @db.Uuid
  tenant_id                String                    @db.Uuid
  source_allocation_run_id String                    @db.Uuid
  cloud_charge_rule_id     String?                   @db.Uuid
  period_start             DateTime                  @db.Timestamptz(6)
  period_end               DateTime                  @db.Timestamptz(6)
  allocated_cost           Decimal                   @db.Decimal(20, 6)
  included_cloud_cost      Decimal                   @default(0) @db.Decimal(20, 6)
  billable_cost            Decimal                   @db.Decimal(20, 6)
  markup_type              String
  markup_value             Decimal                   @db.Decimal(20, 6)
  minimum_monthly_charge   Decimal                   @default(0) @db.Decimal(20, 6)
  gross_charge_amount      Decimal                   @db.Decimal(20, 6)
  discount_amount          Decimal                   @default(0) @db.Decimal(20, 6)
  final_charge_amount      Decimal                   @db.Decimal(20, 6)
  margin_amount            Decimal                   @db.Decimal(20, 6)
  margin_percentage        Decimal?                  @db.Decimal(20, 6)
  currency                 String
  status                   String                    @default("draft")
  metadata                 Json
  created_at               DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)
  calculation_run          CloudChargeCalculationRun @relation(fields: [calculation_run_id], references: [id], onDelete: Cascade)
  tenant                   Tenant                    @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  source_allocation_run    CloudCostAllocationRun    @relation(fields: [source_allocation_run_id], references: [id], onDelete: Restrict)
  cloud_charge_rule        CloudChargeRule?          @relation(fields: [cloud_charge_rule_id], references: [id], onDelete: SetNull)

  @@unique([calculation_run_id, tenant_id])
  @@index([tenant_id])
  @@index([period_start, period_end])
  @@index([calculation_run_id])
  @@index([source_allocation_run_id])
  @@index([cloud_charge_rule_id])
  @@index([status])
  @@map("tenant_cloud_charges")
}

model TenantCloudCostAllocation {
  id                          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  allocation_run_id           String                 @db.Uuid
  tenant_id                   String                 @db.Uuid
  provider                    String
  period_start                DateTime               @db.Timestamptz(6)
  period_end                  DateTime               @db.Timestamptz(6)
  service_code                String
  usage_type                  String                 @default("unknown")
  cost_category               String                 @default("unknown")
  allocation_method           String
  allocation_basis_metric_key String?
  allocation_basis_quantity   Decimal                @default(0) @db.Decimal(20, 6)
  allocation_ratio            Decimal                @default(0) @db.Decimal(20, 12)
  allocated_cost              Decimal                @db.Decimal(20, 6)
  currency                    String
  source_cost_line_item_ids   Json
  metadata                    Json
  created_at                  DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  allocation_run              CloudCostAllocationRun @relation(fields: [allocation_run_id], references: [id], onDelete: Cascade)
  tenant                      Tenant                 @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([allocation_run_id, tenant_id, service_code, usage_type, cost_category, allocation_method])
  @@index([allocation_run_id])
  @@index([tenant_id])
  @@index([period_start, period_end])
