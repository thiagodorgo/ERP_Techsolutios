/// F7a (Estoque core) — catalog item. The BALANCE IS NEVER A COLUMN (R7.1):
/// saldo = SUM(stock_movements.quantidade_sinalizada) computed in a transaction.
/// `avg_cost` is the moving average recalculated on `entrada` (R7.3); `abc_class`
/// is populated by the F7b ABC job (schema-only in F7a — no API write).
model InventoryItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  sku            String
  name           String
  unit           String
  min_quantity   Decimal  @default(0) @db.Decimal(20, 6)
  max_quantity   Decimal? @db.Decimal(20, 6)
  abc_class      String?
  avg_cost       Decimal  @default(0) @db.Decimal(20, 6)
  lead_time_days Int?
  safety_stock   Decimal? @db.Decimal(20, 6)
  is_active      Boolean  @default(true)
  created_by     String?  @db.Uuid
  updated_by     String?  @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenant         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  movements      StockMovement[]
  cycle_count_entries CycleCountEntry[]

  @@unique([tenant_id, id])
  @@unique([tenant_id, sku])
  @@index([tenant_id, is_active])
  @@index([tenant_id, created_at])
  @@map("inventory_items")
}

/// F7a (Estoque core) — IMMUTABLE stock ledger entry (no update/delete surface).
/// `quantidade_sinalizada` is stored SIGNED: + for entrada / positive ajuste,
/// − for saida / consumo / negative ajuste. `work_order_id` (required for
/// consumo, R7.2) and `vehicle_id` are validated in-tenant at the service layer
/// (no hard FK); `cycle_count_id` is a plain column — F7b adds the table.
model StockMovement {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String   @db.Uuid
  item_id               String   @db.Uuid
  type                  String
  quantidade_sinalizada Decimal  @db.Decimal(20, 6)
  unit_cost             Decimal? @db.Decimal(20, 6)
  work_order_id         String?  @db.Uuid
  vehicle_id            String?  @db.Uuid
  reason                String?
  cycle_count_id        String?  @db.Uuid
  created_by            String?  @db.Uuid
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  tenant                Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  item                  InventoryItem @relation(fields: [tenant_id, item_id], references: [tenant_id, id], onDelete: Restrict)
  cycle_count           CycleCount?   @relation(fields: [tenant_id, cycle_count_id], references: [tenant_id, id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@index([tenant_id, item_id, created_at])
  @@index([tenant_id, work_order_id])
  @@index([tenant_id, created_at])
  @@map("stock_movements")
}

/// F7b (Estoque avançado) — contagem cíclica SESSION (R7.6). Snapshots the derived
/// saldo of the chosen `abc_class` (or all active items) into `entries` at open,
/// then generates `ajuste` movements for the variances at close. `status`
/// ('aberta'|'concluida'|'cancelada') is terminal once concluida/cancelada
/// (further mutation = 422). The saldo is NEVER stored here — only the snapshot.
model CycleCount {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  abc_class  String?
  status     String   @default("aberta")
  notes      String?
  is_active  Boolean  @default(true)
  created_by String?  @db.Uuid
  updated_by String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenant     Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  entries    CycleCountEntry[]
  movements  StockMovement[]

  @@unique([tenant_id, id])
  @@index([tenant_id, status])
  @@index([tenant_id, is_active])
  @@index([tenant_id, created_at])
  @@map("cycle_counts")
}

/// F7b (Estoque avançado) — counted line of a `CycleCount`. `system_quantity` is
/// the derived saldo snapshotted at open; `counted_quantity` is filled while
/// counting; `variance` (counted − system) and `adjustment_movement_id` (the
/// generated `ajuste`) are filled at close. One line per item per session.
model CycleCountEntry {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id              String   @db.Uuid
  cycle_count_id         String   @db.Uuid
  item_id                String   @db.Uuid
  system_quantity        Decimal  @db.Decimal(20, 6)
  counted_quantity       Decimal? @db.Decimal(20, 6)
  variance               Decimal? @db.Decimal(20, 6)
  adjustment_movement_id String?  @db.Uuid
  created_at             DateTime @default(now()) @db.Timestamptz(6)
  updated_at             DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenant                 Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  cycle_count            CycleCount    @relation(fields: [tenant_id, cycle_count_id], references: [tenant_id, id], onDelete: Cascade)
  item                   InventoryItem @relation(fields: [tenant_id, item_id], references: [tenant_id, id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@unique([tenant_id, cycle_count_id, item_id])
  @@index([tenant_id, cycle_count_id])
  @@index([tenant_id, item_id])
  @@map("cycle_count_entries")
}

model ServiceCatalog {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                  String   @db.Uuid
  name                       String
  description                String?
  category                   String?
  // Ω3F-2 (C4) — discriminador de tipo: dirige os campos dinâmicos do form (#23) e o 422 de destino (#24).
  // Soft-enum String (reboque|socorro|residencial|outro), NÃO enum Prisma — tipos são configuráveis por
  // organização (spec §1.2). requires_destination separado para o cliente decidir por tipo. Aditivo/nullable.
  service_type               String?
  requires_destination       Boolean  @default(false)
  estimated_duration_minutes Int?
  base_price                 Decimal? @db.Decimal(12, 2)
  status                     String   @default("active")
  is_active                  Boolean  @default(true)
  created_by                 String?  @db.Uuid
  updated_by                 String?  @db.Uuid
  created_at                 DateTime @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenant                     Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  work_orders                WorkOrder[] @relation("WorkOrderServiceCatalog")
  tariffs                    Tariff[]    @relation("TariffService")

  @@unique([tenant_id, id])
  @@unique([tenant_id, name])
  @@index([tenant_id, is_active])
  @@index([tenant_id, created_at])
  @@map("service_catalog")
}

// Ω2-a.1 — Tabela de Valores (contêiner versionado, RN-CAD-007/008). status: draft|published|archived.
model PriceTable {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String    @db.Uuid
  name        String
  description String?
  currency    String    @default("BRL")
  version     Int       @default(1)
  valid_from  DateTime? @db.Timestamptz(6)
  valid_to    DateTime? @db.Timestamptz(6)
  status      String    @default("draft")
  is_active   Boolean   @default(true)
  created_by  String?   @db.Uuid
  updated_by  String?   @db.Uuid
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  tenant      Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  tariffs     Tariff[]

  @@unique([tenant_id, id])
  @@unique([tenant_id, name])
  @@index([tenant_id, is_active])
  @@index([tenant_id, status])
  @@index([tenant_id, created_at])
  @@map("price_tables")
}

// Ω2-a.2 — Tarifa (item de preço), pertence a uma Tabela de Valores. RN-CAD-009.
model Tariff {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String          @db.Uuid
  price_table_id     String          @db.Uuid
  service_catalog_id String?         @db.Uuid
  customer_id        String?         @db.Uuid
  name               String?
  unit_price         Decimal         @db.Decimal(12, 2)
  currency           String          @default("BRL")
  origin             String
  rule               String?
  valid_from         DateTime?       @db.Timestamptz(6)
  valid_to           DateTime?       @db.Timestamptz(6)
  status             String          @default("active")
  is_active          Boolean         @default(true)
  created_by         String?         @db.Uuid
  updated_by         String?         @db.Uuid
  created_at         DateTime        @default(now()) @db.Timestamptz(6)
  updated_at         DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  tenant             Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  price_table        PriceTable      @relation(fields: [tenant_id, price_table_id], references: [tenant_id, id], onDelete: Cascade)
  service_catalog    ServiceCatalog? @relation("TariffService", fields: [tenant_id, service_catalog_id], references: [tenant_id, id], onDelete: Restrict)
  customer           Customer?       @relation("TariffCustomer", fields: [tenant_id, customer_id], references: [tenant_id, id], onDelete: Restrict)

  // A1 (crítico) — chave natural INCLUI customer_id: tarifa padrão (customer NULL) e por-cliente
  // para o mesmo serviço NÃO colidem (NULLs distintos no índice único do Postgres).
  @@unique([tenant_id, price_table_id, service_catalog_id, customer_id])
  @@unique([tenant_id, id])
  @@index([tenant_id, price_table_id])
  @@index([tenant_id, is_active])
  @@map("tariffs")
}

// Ω3-a — ServiceQuote (orçamento): CONGELA preço unitário + total a partir de uma Tarifa de Tabela de
// Valores PUBLICADA, no momento da criação (anti-refaturamento). `source_*` = rastreabilidade apenas
// (nunca relidos para recalcular). Colunas ESCALARES no Prisma; as FKs compostas (tenant_id, X) e o
// índice único PARCIAL da chave natural ativa (WHERE is_active AND status<>'void') são criados em SQL
// bruto na migration — C1 (crítico): a chave natural NÃO pode ser @@unique CHEIO do Prisma, senão
// bloquearia re-orçar após void. RLS ENABLE+FORCE+policy em app.current_tenant_id (SQL bruto).
model ServiceQuote {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String   @db.Uuid
  work_order_id         String?  @db.Uuid
  customer_id           String?  @db.Uuid
  service_catalog_id    String   @db.Uuid
  source_tariff_id      String?  @db.Uuid
  source_price_table_id String?  @db.Uuid
  frozen_unit_price     Decimal  @db.Decimal(12, 2)
  frozen_currency       String   @default("BRL")
  quantity              Decimal  @default(1) @db.Decimal(12, 2)
  frozen_total          Decimal  @db.Decimal(12, 2)
  frozen_at             DateTime @default(now()) @db.Timestamptz(6)
  price_source          String   @default("tariff")
  status                String   @default("draft")
  is_active             Boolean  @default(true)
  notes                 String?
  // Ω3F-4a — cabeçalho do orçamento multi-item (aditivos/nullable; item único legado permanece válido).
  number                String?
  issued_at             DateTime? @db.Timestamptz(6)
  valid_until           DateTime? @db.Timestamptz(6)
  // Ω3F-4b — aprovar→cria OS (idempotência ancorada aqui: um orçamento gera no máx. UMA OS) e compartilhar.
  created_work_order_id String?  @db.Uuid
  share_token           String?
  created_by            String?  @db.Uuid
  updated_by            String?  @db.Uuid
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([tenant_id, id])
  @@index([tenant_id, work_order_id])
  @@index([tenant_id, status])
  @@map("service_quotes")
}

// Ω3F-4a — item (linha) do orçamento multi-item. Espelho 1:1 de WorkOrderFinancialItem (source+description,
// NÃO kind — reuso do shape C3 e do congelamento). CONGELA unit_amount/total_amount a partir da Tarifa
// vigente do cliente (leitura única, anti-refaturamento) ou valor manual. Delete LÓGICO. Idempotência
// tenant-scoped por client_action_id (unique parcial em SQL bruto na migration). FKs compostas RESTRICT + RLS.
model ServiceQuoteItem {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String    @db.Uuid
  service_quote_id String    @db.Uuid
  tariff_id        String?   @db.Uuid
  price_table_id   String?   @db.Uuid
  description      String
  quantity         Decimal   @default(1) @db.Decimal(12, 2)
  unit_amount      Decimal   @db.Decimal(12, 2)
  total_amount     Decimal   @db.Decimal(12, 2)
  currency         String    @default("BRL")
  source           String    @default("tariff")
  notes            String?
  client_action_id String?
  created_by       String?   @db.Uuid
  updated_by       String?   @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at       DateTime? @db.Timestamptz(6)

  @@unique([tenant_id, id])
  @@index([tenant_id, service_quote_id])
  @@map("service_quote_items")
}

// Ω3F-3a — WorkOrderFinancialItem (Financeiro da OS): item lançado que CONGELA unit_amount +
// total_amount no momento do lançamento — source=tariff resolve a Tarifa vigente (a MESMA máquina
// do orçamento) numa ÚNICA leitura; source=manual usa o valor do corpo. tariff_id/price_table_id =
// proveniência apenas (JAMAIS relidos para recalcular — anti-refaturamento). Delete LÓGICO via
// deleted_at. Colunas ESCALARES no Prisma (espelho do ServiceQuote); as FKs compostas (tenant_id, X)
// RESTRICT, o unique PARCIAL de idempotência (tenant_id, work_order_id, client_action_id WHERE
// client_action_id IS NOT NULL AND deleted_at IS NULL) e o RLS ENABLE+FORCE+policy são SQL bruto na
// migration (não expressáveis no schema).
model WorkOrderFinancialItem {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String    @db.Uuid
  work_order_id    String    @db.Uuid
  tariff_id        String?   @db.Uuid
  price_table_id   String?   @db.Uuid
  description      String
  quantity         Decimal   @default(1) @db.Decimal(12, 2)
  unit_amount      Decimal   @db.Decimal(12, 2)
  total_amount     Decimal   @db.Decimal(12, 2)
  currency         String    @default("BRL")
  source           String    @default("tariff")
  notes            String?
  client_action_id String?
  created_by       String?   @db.Uuid
  updated_by       String?   @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at       DateTime? @db.Timestamptz(6)

  @@unique([tenant_id, id])
  @@index([tenant_id, work_order_id])
  @@map("work_order_financial_items")
}

// Ω3F-5 (D-Ω3F-5-COMMENT) — comentário do usuário como AGREGADO PRÓPRIO mutável (deixa WorkOrderEvent
// como audit trail append-only intacto). Editar = PATCH message (carimba edited_at); excluir = delete
// LÓGICO (deleted_at). FKs compostas (tenant_id, work_order_id) → work_orders e (tenant_id,
// author_user_id) → users, RESTRICT (só no SQL da migration; modelo scalar-only, espelho dos vizinhos).
model WorkOrderComment {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String    @db.Uuid
  work_order_id  String    @db.Uuid
  author_user_id String    @db.Uuid
  message        String
  edited_at      DateTime? @db.Timestamptz(6)
  deleted_at     DateTime? @db.Timestamptz(6)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([tenant_id, id])
  @@index([tenant_id, work_order_id])
  @@map("work_order_comments")
}

// Ω3F-5 (D-Ω3F-5-TAGASSIGN) — junção POLIMÓRFICA tag ↔ alvo (entity_type/entity_id). entity_type =
// "work_order_comment" agora; outros depois sem retrabalho. @@unique polimórfico → 409 duplicate.
// SEM FK nativa ao alvo polimórfico (integridade app-level: attach valida alvo/tag). Detach = HARD-delete.
// FK composta (tenant_id, tag_id) → tags RESTRICT (só no SQL da migration; modelo scalar-only).
model TagAssignment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  tag_id      String   @db.Uuid
  entity_type String
  entity_id   String   @db.Uuid
  created_by  String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@unique([tenant_id, id])
  @@unique([tenant_id, entity_type, entity_id, tag_id])
  @@index([tenant_id, entity_type, entity_id])
  @@index([tenant_id, tag_id])
  @@map("tag_assignments")
}

// Ω2-b — Fornecedor (cadastro). Chave natural [tenant_id, name]; desativação lógica via is_active.
model Supplier {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String
  document   String?
  email      String?
  phone      String?
  address    String?
  category   String?
  notes      String?
  status     String   @default("active")
  is_active  Boolean  @default(true)
  created_by String?  @db.Uuid
  updated_by String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@unique([tenant_id, name])
  @@index([tenant_id, is_active])
  @@index([tenant_id, created_at])
  @@map("suppliers")
}

// Ω4-1 — Conta financeira (cadastro puro). kind ∈ {cash,bank,wallet} e currency ∈ {BRL} validados na
// aplicação. opening_balance é Decimal(12,2) ≥ 0 (saldo de abertura; saldo devedor é lançamento).
// A unicidade de NOME é PARCIAL (só entre contas ATIVAS) e vive SÓ no SQL da migration — o Prisma
// não expressa índice único parcial (WHERE is_active=true); por isso NÃO há @@unique([tenant_id,name]).
// Delete é LÓGICO: is_active=false + status='inactive'.
model FinancialAccount {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  name            String
  kind            String   @default("cash")
  currency        String   @default("BRL")
  opening_balance Decimal  @default(0) @db.Decimal(12, 2)
  bank_name       String?
  agency          String?
  account_number  String?
  document        String?
  notes           String?
  status          String   @default("active")
  is_active       Boolean  @default(true)
  created_by      String?  @db.Uuid
  updated_by      String?  @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenant          Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  financial_titles FinancialTitle[]

  @@unique([tenant_id, id])
  @@index([tenant_id, is_active])
  @@index([tenant_id, created_at])
  @@map("financial_accounts")
}

// Ω4-2a — Título financeiro (a pagar/receber): agregado-núcleo do financeiro do tenant. Dinheiro
// DECIMAL(12,2). direction/party_type/status/currency são validados na aplicação (sem enum/CHECK, como
// status/priority da OS). competencia ('YYYY-MM') é DERIVADA de issue_date no servidor. party_id é
// polimórfico (customer/supplier/other) — SEM FK nativa ao alvo variável (integridade app-level, como
// TagAssignment). account_id (conta de liquidação prevista) e work_order_id (proveniência, populado no
// Ω4-3) usam FK composta (tenant_id, X) → (tenant_id, id) RESTRICT — nullable, então o Postgres só exige
// a FK quando a coluna não é NULL. paid_amount é DIRIGIDO por pagamentos (Ω4-4): nasce 0 aqui. Delete
// LÓGICO via deleted_at.
model FinancialTitle {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String    @db.Uuid
  direction        String // receivable|payable (app-level)
  party_type       String // customer|supplier|other
  party_id         String?   @db.Uuid // polimórfico: SEM FK nativa ao alvo variável
  party_name       String // snapshot obrigatório
  document         String? // rótulo NF-e/Fatura/Boleto (texto livre; NF-e não emitida no v1)
  category         String?
  description      String?
  amount           Decimal   @db.Decimal(12, 2) // > 0
  currency         String    @default("BRL") // allowlist {BRL} no v1
  issue_date       DateTime  @default(now()) @db.Timestamptz(6)
  due_date         DateTime  @db.Timestamptz(6) // obrigatório
  paid_amount      Decimal   @default(0) @db.Decimal(12, 2) // <= amount; dirigido por pagamentos (Ω4-4)
  status           String    @default("open") // open|scheduled|partially_paid|paid|in_dispute|cancelled
  competencia      String // 'YYYY-MM' derivado do issue_date (server-side)
  account_id       String?   @db.Uuid // conta de liquidação prevista (FK composta)
  work_order_id    String?   @db.Uuid // proveniência (setado no Ω4-3; sem idempotência aqui)
  service_quote_id String?   @db.Uuid // proveniência
  client_action_id String?
  created_by       String?   @db.Uuid
  updated_by       String?   @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at       DateTime? @db.Timestamptz(6)
  tenant           Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  account          FinancialAccount? @relation(fields: [tenant_id, account_id], references: [tenant_id, id], onDelete: Restrict)
  work_order       WorkOrder?        @relation(fields: [tenant_id, work_order_id], references: [tenant_id, id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@index([tenant_id, direction, status])
  @@index([tenant_id, due_date])
  @@index([tenant_id, deleted_at])
  @@map("financial_titles")
}

// Ω4-2a — Fechamento de período financeiro (MÍNIMO). Só habilita o CHOKEPOINT assertPeriodOpen: toda
// escrita de título consulta (tenant_id, period=competencia); period 'closed' bloqueia a escrita (422
// period_closed). Nesta fatia NÃO há endpoint de escrita (fechar/reabrir vem no Ω4-6) — a tabela nasce
// vazia e o guard nunca bloqueia, mas a fiação é REAL.
model FinancialPeriodClose {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String    @db.Uuid
  period     String // 'YYYY-MM'
  status     String    @default("open") // open|closing|closed|reopened
  closed_at  DateTime? @db.Timestamptz(6)
  closed_by  String?   @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@unique([tenant_id, period])
  @@map("financial_period_closes")
}

// Ω2-d — Tag (marcador/etiqueta). Chave natural [tenant_id, name]; desativação lógica via is_active.
// color opcional em hex (#RRGGBB), validado na aplicação.
model Tag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  name        String
  color       String?
  description String?
  is_active   Boolean  @default(true)
  created_by  String?  @db.Uuid
  updated_by  String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@unique([tenant_id, name])
  @@index([tenant_id, is_active])
  @@index([tenant_id, created_at])
  @@map("tags")
}

// Ω2-d — POI (ponto de interesse geográfico). Chave natural [tenant_id, name]; latitude/longitude
// NUMERIC(10,7) obrigatórios, validados pelo predicado do mapa Ω1 (finito, |lat|<=90, |lng|<=180,
// sem sentinela 0/0). Desativação lógica via is_active.
model Poi {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String
  category   String?
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  address    String?
  is_active  Boolean  @default(true)
  created_by String?  @db.Uuid
  updated_by String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@unique([tenant_id, name])
  @@index([tenant_id, is_active])
  @@index([tenant_id, created_at])
  @@map("pois")
}

// Ω2-e — Parâmetro (cadastro key-value administrativo do tenant). Chave natural [tenant_id, key]
// (upsert por chave). value é @db.Text e pode conter JSON serializado. Sem delete físico: upsert
// sobrescreve o valor. Território de admin (RBAC tenant_settings:read/update).
model TenantSetting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  key         String
  value       String   @db.Text
  category    String?
  description String?
  updated_by  String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, key])
  @@unique([tenant_id, id])
  @@index([tenant_id, category])
  @@map("tenant_settings")
}

// Ω2-c — Profissional (perfil profissional do operador de campo). Extensão 1-1 de User (unique
// [tenant_id, user_id] → 409 duplicate_profile). Dado sensível LGPD: CNH e consentimento de rastreamento.
// FK composta (tenant_id, user_id) → users(tenant_id, id) ON DELETE Cascade (apagar o usuário remove o
// perfil). user_id imutável no update. Desativação lógica via is_active.
model OperatorProfile {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String    @db.Uuid
  user_id             String    @db.Uuid
  full_name           String?
  cnh_number          String?
  cnh_category        String?
  cnh_expires_at      DateTime? @db.Timestamptz(6)
  tracking_consent    Boolean   @default(false)
  tracking_consent_at DateTime? @db.Timestamptz(6)
  phone               String?
  notes               String?
  is_active           Boolean   @default(true)
  created_by          String?   @db.Uuid
  updated_by          String?   @db.Uuid
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
