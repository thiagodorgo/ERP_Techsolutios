model ChecklistAcknowledgement {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String       @db.Uuid
  run_id          String       @db.Uuid
  acknowledged_by String       @db.Uuid
  message         String
  observation     String?
  acknowledged_at DateTime     @default(now()) @db.Timestamptz(6)
  metadata        Json
  run             ChecklistRun @relation(fields: [tenant_id, run_id], references: [tenant_id, id], onDelete: Cascade)
  tenant          Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

