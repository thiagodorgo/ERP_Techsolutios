model WorkOrder {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String                @db.Uuid
  code                  String
  title                 String
  description           String?
  customer_name         String?
  customer_document     String?
  customer_phone        String?
  service_address       String?
  service_city          String?
  service_state         String?
  service_zip_code      String?
  service_latitude      Decimal?              @db.Decimal(10, 7)
  service_longitude     Decimal?              @db.Decimal(10, 7)
  priority              String                @default("medium")
  status                String                @default("open")
  assigned_operator_id  String?               @db.Uuid
  assigned_user_id      String?               @db.Uuid
  checklist_id          String?               @db.Uuid
  scheduled_for         DateTime?             @db.Timestamptz(6)
  started_at            DateTime?             @db.Timestamptz(6)
  arrived_at            DateTime?             @db.Timestamptz(6)
  completed_at          DateTime?             @db.Timestamptz(6)
  cancelled_at          DateTime?             @db.Timestamptz(6)
  cancellation_reason   String?
  created_by            String?               @db.Uuid
  updated_by            String?               @db.Uuid
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  updated_at            DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  assignments           WorkOrderAssignment[]
  field_dispatch_events FieldDispatchEvent[]
