model ExpenseReceipt {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String      @db.Uuid
  item_id       String      @db.Uuid
  file_key      String?
  local_hash    String
  mime_type     String
  ocr_text      String?
  ocr_fields    Json?
  confidence    Decimal?    @db.Decimal(8, 6)
  upload_status String      @default("local")
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  item          ExpenseItem @relation(fields: [tenant_id, item_id], references: [tenant_id, id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@index([tenant_id])
  @@index([tenant_id, item_id])
  @@index([tenant_id, local_hash])
  @@index([tenant_id, upload_status])
  @@map("expense_receipts")
}

model ExpenseAdvance {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String         @db.Uuid
  employee_user_id String         @db.Uuid
  report_id        String?        @db.Uuid
  amount           Decimal        @db.Decimal(20, 6)
  currency         String         @default("BRL")
  source           String         @default("manual")
  status           String         @default("open")
  issued_at        DateTime       @db.Timestamptz(6)
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  employee         User           @relation("ExpenseAdvanceEmployee", fields: [tenant_id, employee_user_id], references: [tenant_id, id], onDelete: Restrict)
  report           ExpenseReport? @relation(fields: [tenant_id, report_id], references: [tenant_id, id], onDelete: Restrict)
  tenant           Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@index([tenant_id])
  @@index([tenant_id, employee_user_id])
  @@index([tenant_id, report_id])
  @@index([tenant_id, status])
  @@map("expense_advances")
}

model ExpenseApprovalStep {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String        @db.Uuid
  report_id     String        @db.Uuid
  step_type     String
  actor_user_id String?       @db.Uuid
  decision      String        @default("pending")
  reason        String?
  decided_at    DateTime?     @db.Timestamptz(6)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  actor_user    User?         @relation("ExpenseApprovalStepActor", fields: [tenant_id, actor_user_id], references: [tenant_id, id], onDelete: Restrict)
  report        ExpenseReport @relation(fields: [tenant_id, report_id], references: [tenant_id, id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@index([tenant_id])
  @@index([tenant_id, report_id])
  @@index([tenant_id, step_type])
  @@index([tenant_id, decision])
  @@map("expense_approval_steps")
}

model ExpenseEvent {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String        @db.Uuid
  aggregate_id  String        @db.Uuid
  event_type    String
  payload_hash  String
  actor_user_id String?       @db.Uuid
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  actor_user    User?         @relation("ExpenseEventActor", fields: [tenant_id, actor_user_id], references: [tenant_id, id], onDelete: Restrict)
  report        ExpenseReport @relation(fields: [tenant_id, aggregate_id], references: [tenant_id, id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@index([tenant_id])
  @@index([tenant_id, aggregate_id])
  @@index([tenant_id, event_type])
  @@map("expense_events")
}

model MobileActionReceipt {
  tenant_id        String    @db.Uuid
  client_action_id String
  actor_user_id    String    @db.Uuid
  action_type      String
  status           String    @default("processed")
  result_ref       String?
  processed_at     DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  actor_user       User      @relation("MobileActionReceiptActor", fields: [tenant_id, actor_user_id], references: [tenant_id, id], onDelete: Restrict)
  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Restrict)

  @@id([tenant_id, client_action_id])
  @@index([tenant_id])
  @@index([tenant_id, actor_user_id])
  @@index([tenant_id, action_type])
  @@index([tenant_id, status])
  @@map("mobile_action_receipts")
}
