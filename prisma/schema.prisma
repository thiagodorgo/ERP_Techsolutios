model WorkOrder {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String                @db.Uuid
  code                  String
  title                 String
  description           String?
  customer_name         String?
  customer_document     String?
  customer_phone        String?
  service_address       String?
  service_city          String?
  service_state         String?
  service_zip_code      String?
  service_latitude      Decimal?              @db.Decimal(10, 7)
  service_longitude     Decimal?              @db.Decimal(10, 7)
  service_geocoded_at   DateTime?             @db.Timestamptz(6)
  service_geocode_source String?
  // Ω3F-2 — DESTINO (a origem = os campos service_* acima, mantidos sem rename para retrocompat).
  // Aditivo/nullable, espelho simétrico da origem. Preenchido quando o tipo do serviço exige destino (#24).
  destination_address   String?
  destination_city      String?
  destination_state     String?
  destination_zip_code  String?
  destination_latitude  Decimal?              @db.Decimal(10, 7)
  destination_longitude Decimal?              @db.Decimal(10, 7)
  destination_geocoded_at DateTime?           @db.Timestamptz(6)
  destination_geocode_source String?
  // Ω3F-2 — campos dinâmicos por tipo (#23): socorro {plate,vehicle,color}; residencial {access_code,object,
  // description}. §2.8: access_code (senha de acesso) é SENSÍVEL — vive aqui (payload funcional), NUNCA em
  // metadata de evento/auditoria/log.
  service_details       Json?
  priority              String                @default("medium")
  status                String                @default("open")
  assigned_operator_id  String?               @db.Uuid
  assigned_user_id      String?               @db.Uuid
  checklist_id          String?               @db.Uuid
  // Ω3-c — snapshot JSON durável do template de checklist, CONGELADO no despacho (FieldDispatch.create).
  // Cópia imutável (não FK); editar o template depois não altera o snapshot. Aditivo/nullable.
  checklist_snapshot    Json?
  customer_id           String?               @db.Uuid
  vehicle_id            String?               @db.Uuid
  team_id               String?               @db.Uuid
  service_catalog_id    String?               @db.Uuid
  scheduled_for         DateTime?             @db.Timestamptz(6)
  started_at            DateTime?             @db.Timestamptz(6)
  arrived_at            DateTime?             @db.Timestamptz(6)
  completed_at          DateTime?             @db.Timestamptz(6)
  cancelled_at          DateTime?             @db.Timestamptz(6)
  cancellation_reason   String?
  // Ω3F-6 (D-Ω3F-6-CANCEL) — decisão financeira do cancelamento: keep | keep_unpaid | zero. Validada na
  // aplicação (sem enum/CHECK, como status/priority). FONTE DE VERDADE para o módulo de comissões honrar
  // depois (P-Ω3F6-COMISSAO). NULL = OS nunca cancelada por este fluxo. Aditivo/nullable.
  financial_cancellation_decision String?
  // Ω3F-6 (D-Ω3F-6-DUPLICATE) — idempotência do DUPLICATE (GAP-1 do dossiê Ω3F-4). O unique PARCIAL
  // (tenant_id, client_action_id) WHERE client_action_id IS NOT NULL NÃO é expressável aqui (Prisma não
  // modela índice parcial) — vive só na migration 20260806000000, como nos vizinhos. O create normal de
  // OS não carimba (NULL cai fora do índice parcial).
  client_action_id      String?
  // Ω3F-7a — Quilometragem (km) da OS: o app PREENCHE (via sync), a base CORRIGE (via PATCH). Aditivo/
  // nullable. mileage_source = "app" | "base" (validado na aplicação, sem enum/CHECK, como status/priority).
  // mileage_corrected_at carimba a correção da base (source="base"). Faixa (end >= start) e valor (>= 0)
  // validados no serviço (setMileage/parseOptionalMileage).
  mileage_start         Decimal?              @db.Decimal(10, 1)
  mileage_end           Decimal?              @db.Decimal(10, 1)
  mileage_source        String?
  mileage_corrected_at  DateTime?             @db.Timestamptz(6)
  created_by            String?               @db.Uuid
  updated_by            String?               @db.Uuid
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  updated_at            DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  assignments           WorkOrderAssignment[]
  field_dispatch_events FieldDispatchEvent[]
  field_dispatches      FieldDispatch[]
  expense_reports       ExpenseReport[]
  attachments           WorkOrderAttachment[]
  financial_titles      FinancialTitle[]
  assigned_user         User?                 @relation("WorkOrderAssignedUser", fields: [tenant_id, assigned_user_id], references: [tenant_id, id], onDelete: Restrict)
  checklist             ChecklistTemplate?    @relation(fields: [tenant_id, checklist_id], references: [tenant_id, id], onDelete: Restrict)
  customer              Customer?             @relation("WorkOrderCustomer", fields: [tenant_id, customer_id], references: [tenant_id, id], onDelete: Restrict)
  vehicle               Vehicle?              @relation("WorkOrderVehicle", fields: [tenant_id, vehicle_id], references: [tenant_id, id], onDelete: Restrict)
  team                  Team?                 @relation("WorkOrderTeam", fields: [tenant_id, team_id], references: [tenant_id, id], onDelete: Restrict)
  service_catalog       ServiceCatalog?       @relation("WorkOrderServiceCatalog", fields: [tenant_id, service_catalog_id], references: [tenant_id, id], onDelete: Restrict)
  created_by_user       User?                 @relation("WorkOrderCreatedBy", fields: [tenant_id, created_by], references: [tenant_id, id], onDelete: Restrict)
  events                WorkOrderEvent[]
  tenant                Tenant                @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
  updated_by_user       User?                 @relation("WorkOrderUpdatedBy", fields: [tenant_id, updated_by], references: [tenant_id, id], onDelete: Restrict)

  @@unique([tenant_id, id])
  @@unique([tenant_id, code])
  @@index([tenant_id, status])
  @@index([tenant_id, priority])
  @@index([tenant_id, assigned_operator_id])
  @@index([tenant_id, assigned_user_id])
  @@index([tenant_id, customer_id])
  @@index([tenant_id, vehicle_id])
  @@index([tenant_id, team_id])
  @@index([tenant_id, service_catalog_id])
  @@index([tenant_id, scheduled_for])
  @@index([tenant_id, created_at])
  @@map("work_orders")
}

