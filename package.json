{
  "name": "erp-techsolutions",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS ERP operacional de campo multi-tenant com backend Node.js + TypeScript.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "web:dev": "npm --prefix frontend run dev",
    "web:build": "npm --prefix frontend run build",
    "web:check": "npm --prefix frontend run check",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx tests/core-saas.test.ts",
    "test:e2e": "npm run db:seed && playwright test -c playwright.config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:seed:fleet": "tsx prisma/seed-fleet.ts",
    "db:studio": "prisma studio",
    "lint": "npm run check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "jose": "^6.2.3",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "prisma": "^7.8.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
